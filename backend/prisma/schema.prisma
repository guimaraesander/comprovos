generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TECNICO
}

enum ServiceOrderStatus {
  ABERTA
  EM_ANALISE
  AGUARDANDO_APROVACAO
  EM_MANUTENCAO
  FINALIZADA
  ENTREGUE
  CANCELADA
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(TECNICO)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  serviceOrders ServiceOrder[] @relation("CreatedByUser")

  @@map("users")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  cpfCnpj   String?
  rgIe      String?
  address   String?
  district  String?
  city      String?
  state     String?
  zipCode   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrders ServiceOrder[]

  @@map("clients")
}

model ServiceOrder {
  id              String             @id @default(cuid())
  osNumber         Int                @unique @default(autoincrement())

  clientId         String
  createdByUserId  String?
  entryDate        DateTime           @default(now())

  // ✅ dados do cliente "congelados" na OS
  clientCpfCnpj    String

  // ✅ dados do equipamento preenchidos na OS (não é entidade separada)
  equipmentType          String
  equipmentBrand         String?
  equipmentModel         String?
  equipmentSerialNumber  String?
  equipmentPassword      String?

  // dados da OS
  symptoms         String
  accessories      String?
  observations     String?

  status           ServiceOrderStatus @default(ABERTA)

  budgetValue      Decimal?           @db.Decimal(10, 2)
  finalValue       Decimal?           @db.Decimal(10, 2)

  webKey           String?            @unique
  trackingPassword String?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  client           Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdByUser    User?              @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  history          ServiceOrderHistory[]

  @@index([clientId])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderHistory {
  id             String             @id @default(cuid())
  serviceOrderId String
  previousStatus ServiceOrderStatus?
  newStatus      ServiceOrderStatus
  note           String?
  createdAt      DateTime           @default(now())

  serviceOrder   ServiceOrder       @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_history")
}