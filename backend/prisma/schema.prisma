generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TECNICO
}

enum ServiceOrderStatus {
  ABERTA
  EM_ANALISE
  AGUARDANDO_APROVACAO
  EM_MANUTENCAO
  FINALIZADA
  ENTREGUE
  CANCELADA
}

enum PaymentType {
  PIX
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  TRANSFERENCIA
  BOLETO
  OUTRO
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(TECNICO)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  serviceOrders ServiceOrder[] @relation("CreatedByUser")

  @@map("users")
}

model Client {
  id            String         @id @default(cuid())
  name          String
  phone         String
  email         String?
  cpfCnpj       String         @unique
  rgIe          String?
  address       String?
  district      String?
  city          String?
  state         String?
  zipCode       String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  serviceOrders ServiceOrder[]

  @@index([cpfCnpj])
  @@map("clients")
}

model ServiceOrder {
  id                     String              @id @default(cuid())
  osNumber               Int                 @unique @default(autoincrement())

  clientId               String
  createdByUserId        String?
  entryDate              DateTime            @default(now())

  clientCpfCnpj          String

  equipmentType          String
  equipmentBrand         String?
  equipmentModel         String?
  equipmentSerialNumber  String?
  equipmentPassword      String?

  symptoms               String
  accessories            String?
  observations           String?

  status                 ServiceOrderStatus  @default(ABERTA)

  budgetValue            Decimal?            @db.Decimal(10, 2)
  finalValue             Decimal?            @db.Decimal(10, 2)

  paymentType            PaymentType?
  paymentDate            DateTime?
  pickupDate             DateTime?

  webKey                 String?             @unique
  trackingPassword       String?

  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  client                 Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdByUser          User?               @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  history                ServiceOrderHistory[]
  budget                 ServiceOrderBudget?

  @@index([clientId])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderHistory {
  id             String             @id @default(cuid())
  serviceOrderId String
  previousStatus ServiceOrderStatus?
  newStatus      ServiceOrderStatus
  note           String?
  createdAt      DateTime           @default(now())

  serviceOrder   ServiceOrder       @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_history")
}

model ServiceOrderBudget {
  id             String                 @id @default(cuid())
  serviceOrderId String                 @unique

  travelFee      Decimal                @db.Decimal(10, 2) @default(0)
  thirdPartyFee  Decimal                @db.Decimal(10, 2) @default(0)
  discount       Decimal                @db.Decimal(10, 2) @default(0)

  note           String?
  approvedAt     DateTime?
  rejectedAt     DateTime?

  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  serviceOrder   ServiceOrder           @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  items          ServiceOrderBudgetItem[]

  @@index([serviceOrderId])
  @@map("service_order_budgets")
}

model ServiceOrderBudgetItem {
  id          String               @id @default(cuid())
  budgetId    String

  description String
  technician  String?
  qty         Int                  @default(1)
  unitValue   Decimal              @db.Decimal(10, 2)

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  budget      ServiceOrderBudget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@map("service_order_budget_items")
}